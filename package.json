{
  "name": "peer-match",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:clean && concurrently --names \"PeerMatch Main Web,PeerMatch Main API\" --prefix-colors \"#0069A8,#FA642C\" \"npm run dev:next\" \"npm run dev:server\"",
    "dev:clean": "npx kill-port 3000 5000",
    "dev:next": "node --title=\"PeerMatch Main\" node_modules/next/dist/bin/next dev --webpack",
    "dev:server": "nodemon --exec \"node --title=\\\"PeerMatch Main\\\"\" server/devMainApi.js",
    "build": "next build",
    "start": "next start",
    "start:server": "node server/server.js",
    "seed:admin": "node server/seedAdmin.js",
    "seed:tasks": "node server/seedTasks.js",
    "lint": "eslint"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "emoji-picker-react": "^4.18.0",
    "express": "^4.18.4",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.472.0",
    "mongodb": "^7.1.1",
    "mongoose": "^7.8.9",
    "next": "16.2.6",
    "nodemailer": "^8.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "kill-port": "^2.0.1",
    "nodemon": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
