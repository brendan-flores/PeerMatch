PORT=5000

# Admin bootstrap (run: npm run seed:admin) — use a strong password; never commit real values
# SEED_ADMIN_EMAIL=admin@peermatch.com
# SEED_ADMIN_PASSWORD=change-me-min-8-chars
# SEED_ADMIN_NAME=PeerMatch Admin

# JWT (use a long random string in production, 32+ characters)
# Generated secret for production:
JWT_SECRET=de669b7e6b16475818976bd96ca981474b1a762b65730b94e4be0983bc8ab011
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=peermatch_token
# Max-Age in ms (default 7d if unset)
# JWT_COOKIE_MAX_AGE_MS=604800000
# Cross-site frontends (e.g. admin on another domain): JWT_COOKIE_SAMESITE=none, Secure cookies, HTTPS
# JWT_COOKIE_SAMESITE=lax
# JWT_COOKIE_SECURE=true
# Share cookie across subdomains: COOKIE_DOMAIN=.peermatch.com

# Comma-separated browser origins allowed to call the API with credentials
# Include every Vercel domain (main + admin) and local dev ports
# Production (replace with your actual Vercel domains):
# CORS_ORIGINS=https://peermatch-app.vercel.app,https://peermatch-admin.vercel.app
# Local development:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Behind a reverse proxy (nginx, Render, Railway, etc.) for correct secure cookies / IPs
# TRUST_PROXY=1

# --- Next.js (Vercel) — required for production ---
# Option A: proxy via same domain (API_PROXY_URL). Registration no longer waits on SMTP, but cold starts can still be slow.
API_PROXY_URL=https://peermatch-api.onrender.com
#
# Option B (recommended on Vercel Hobby): browser calls Render directly — avoids FUNCTION_INVOCATION_TIMEOUT
# Set on Vercel AND add your Vercel URL to CORS_ORIGINS on Render, then redeploy both.
NEXT_PUBLIC_API_BASE_URL=https://peermatch-api.onrender.com
#
# Your Vercel domains (update after deployment):
NEXT_PUBLIC_MAIN_SITE_URL=https://peermatch-app.vercel.app
NEXT_PUBLIC_ADMIN_SITE_URL=https://peermatch-admin.vercel.app

# Hostnames only (no https) — middleware splits main vs admin on one or two Vercel projects
# Your Vercel hostnames (update after deployment):
MAIN_SITE_HOSTS=peermatch-app.vercel.app,localhost:3000
ADMIN_SITE_HOSTS=peermatch-admin.vercel.app,localhost:3001
# NEXT_PUBLIC_MAIN_SITE_HOST=peermatch-app.vercel.app
# NEXT_PUBLIC_ADMIN_SITE_HOST=peermatch-admin.vercel.app

# Cross-domain cookies: API sets httpOnly cookies; use SameSite=None + Secure in production
# JWT_COOKIE_SAMESITE=none
# JWT_COOKIE_SECURE=true

# API deployed host (documentation)
# API_PUBLIC_URL=https://api.yourdomain.com

# --- Email: Supabase Edge Function + Resend (recommended for production) ---
