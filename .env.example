# Copy to .env and fill in real values. Never commit .env.
# Save .env as UTF-8 (not UTF-16) in your editor.

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/peer-match
# Production Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/peer-match?retryWrites=true&w=majority

PORT=5000

# JWT — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=peermatch_token

CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=1

# Next.js (Vercel)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
API_PROXY_URL=http://localhost:5000
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
MAIN_SITE_HOSTS=localhost:3000
NEXT_PUBLIC_ADMIN_SITE_URL=http://localhost:3000
# ADMIN_SITE_HOSTS=   (omit locally — open http://localhost:3000/admin)

# Production admin on separate domain:
# NEXT_PUBLIC_ADMIN_SITE_URL=https://peermatch-admin.vercel.app
# ADMIN_SITE_HOSTS=peermatch-admin.vercel.app

# Supabase Auth — email OTP (replaces SMTP/Nodemailer)
# Dashboard: Project Settings → API Keys
SUPABASE_URL=https://your-project-ref.supabase.co
# Use ONE of these (publishable key preferred on newer projects):
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_ANON_KEY=eyJ...   (legacy JWT anon key — only if enabled in dashboard)
INSTITUTIONAL_EMAIL_DOMAIN=cit.edu

# Admin seed: npm run seed:admin
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-min-8-chars
