# Supabase (see docs/SUPABASE-EMAIL-SETUP.md). SMTP below is ignored in that case.
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_secret...
# SUPABASE_EMAIL_FUNCTION=send-verification-email

