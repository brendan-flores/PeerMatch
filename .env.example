# Local MongoDB connection
MONGODB_URI=mongodb://127.0.0.1:27017/peer-match

# Atlas connection example (replace <db_password> before using)
# MONGODB_URI="mongodb+srv://peermatch_db_user:<db_password>@peer-match-cluster.ygz4cge.mongodb.net/peer-match?retryWrites=true&w=majority"
PORT=5000

# Admin bootstrap (run: npm run seed:admin) — use a strong password; never commit real values
# SEED_ADMIN_EMAIL=admin@peermatch.com
# SEED_ADMIN_PASSWORD=change-me-min-8-chars
# SEED_ADMIN_NAME=PeerMatch Admin

# JWT (use a long random string in production, 32+ characters)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=peermatch_token
# Max-Age in ms (default 7d if unset)
# JWT_COOKIE_MAX_AGE_MS=604800000
# Cross-site frontends (e.g. admin on another domain): JWT_COOKIE_SAMESITE=none, Secure cookies, HTTPS
# JWT_COOKIE_SAMESITE=lax
# JWT_COOKIE_SECURE=true
# Share cookie across subdomains: COOKIE_DOMAIN=.peermatch.com

# Comma-separated browser origins allowed to call the API with credentials
# Include every Vercel domain (main + admin) and local dev ports
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Behind a reverse proxy (nginx, Render, Railway, etc.) for correct secure cookies / IPs
# TRUST_PROXY=1

# --- Next.js (Vercel) — set on BOTH frontend deployments ---
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com
# NEXT_PUBLIC_MAIN_SITE_URL=https://app.yourdomain.com
# NEXT_PUBLIC_ADMIN_SITE_URL=https://admin.yourdomain.com

# Hostnames only (no https) — middleware splits main vs admin on one or two Vercel projects
# MAIN_SITE_HOSTS=app.yourdomain.com,localhost:3000
# ADMIN_SITE_HOSTS=admin.yourdomain.com,localhost:3001
# NEXT_PUBLIC_MAIN_SITE_HOST=app.yourdomain.com
# NEXT_PUBLIC_ADMIN_SITE_HOST=admin.yourdomain.com

# Cross-domain cookies: API sets httpOnly cookies; use SameSite=None + Secure in production
# JWT_COOKIE_SAMESITE=none
# JWT_COOKIE_SECURE=true

# API deployed host (documentation)
# API_PUBLIC_URL=https://api.yourdomain.com

# Nodemailer email delivery settings
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email-user
EMAIL_PASS=your-email-password
EMAIL_FROM="PeerMatch <no-reply@example.com>"
VERIFICATION_CODE_TTL_MINUTES=10

# Outlook SMTP example
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USER=your-outlook@outlook.com
# EMAIL_PASS=your-outlook-app-password
# EMAIL_FROM="PeerMatch <your-outlook@outlook.com>"
