# Copy to .env (local). Never commit .env.
# Save as UTF-8 (not UTF-16).

# ─── Render API (local) ─────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=peermatch_token
JWT_COOKIE_SAMESITE=lax
JWT_COOKIE_SECURE=false
TRUST_PROXY=1
INSTITUTIONAL_EMAIL_DOMAIN=cit.edu
PORT=5000
CORS_ORIGINS=http://localhost:3000

# Supabase (required for database + email OTP)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Next.js (local) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
# Optional override for server proxy; Vercel uses NEXT_PUBLIC_API_BASE_URL instead.
API_PROXY_URL=http://localhost:5000
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
MAIN_SITE_HOSTS=localhost:3000
NEXT_PUBLIC_ADMIN_SITE_URL=http://localhost:3000

# Do NOT put on Vercel: JWT_SECRET, SUPABASE_*, EMAIL_*, RESEND_*
# Do NOT put on Render: NEXT_PUBLIC_*, MAIN_SITE_HOSTS, ADMIN_SITE_HOSTS

# ─── Render production (see docs/DEPLOY_ENV.md) ─────────────────────────────
# CORS_ORIGINS=https://peermatch-app.site,https://www.peermatch-app.site,...
# JWT_COOKIE_SAMESITE=none
# JWT_COOKIE_SECURE=true
# NODE_ENV=production

# ─── Vercel production (see docs/DEPLOY_ENV.md) ───────────────────────────
# NEXT_PUBLIC_API_BASE_URL=https://peermatch-api.onrender.com
# NEXT_PUBLIC_MAIN_SITE_URL=https://peermatch-app.site
# MAIN_SITE_HOSTS=peermatch-app.site,www.peermatch-app.site,peermatch-app.vercel.app
# API_PROXY_URL is optional — proxy uses NEXT_PUBLIC_API_BASE_URL when unset
