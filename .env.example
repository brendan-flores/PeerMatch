# Copy to .env and fill in real values. Never commit .env.
# Save .env as UTF-8 (not UTF-16) in your editor.

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/peer-match
# Production Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/peer-match?retryWrites=true&w=majority

PORT=5000

# JWT — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=peermatch_token

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TRUST_PROXY=1

# Next.js (Vercel)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
API_PROXY_URL=http://localhost:5000
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_SITE_URL=http://localhost:3001

# Email — SMTP (required for @cit.edu delivery)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password-16-chars
EMAIL_FROM_NAME=PeerMatch
EMAIL_FROM_EMAIL=your-gmail@gmail.com
EMAIL_SYNC_SEND=true
VERIFICATION_CODE_TTL_MINUTES=10
INSTITUTIONAL_EMAIL_DOMAIN=cit.edu

# Admin seed: npm run seed:admin
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-min-8-chars
